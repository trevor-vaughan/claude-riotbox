#!/usr/bin/env bash
# bin/riotbox — RiotBox CLI dispatcher.
# Self-locates the install tree and routes verbs directly to libexec/ and
# scripts/ helpers. No task runner is involved at runtime.
set -euo pipefail

# ── Self-location ─────────────────────────────────────────────────────────
# readlink -f resolves the /usr/bin or ~/.local/bin symlink to the real file;
# the grandparent of bin/riotbox is the install root (/opt/riotbox,
# ~/.local/share/riotbox, or the repo when run as ./bin/riotbox).
SELF="$(readlink -f "${BASH_SOURCE[0]}")"
RIOTBOX_DIR="$(cd "$(dirname "${SELF}")/.." && pwd)"
export RIOTBOX_DIR
# Helper scripts were written for the task era and read ${ROOT_DIR}; honor it.
export ROOT_DIR="${RIOTBOX_DIR}"

LIBEXEC="${RIOTBOX_DIR}/libexec"
SCRIPTS="${RIOTBOX_DIR}/scripts"
VERSION="$(cat "${RIOTBOX_DIR}/VERSION" 2>/dev/null || echo "unknown")"

# ── Shared environment exported to every helper ───────────────────────────
CONTAINER_CMD="$(command -v podman 2>/dev/null || echo docker)"
export CONTAINER_CMD
export IMAGE_NAME="${IMAGE_NAME:-riotbox}"

# Agent registry: validates --agent and powers `agents`. Sourced at runtime so
# newly added agents are picked up without reinstalling.
# shellcheck disable=SC1091
source "${RIOTBOX_DIR}/agents/registry.sh"

ensure_image() { "${LIBEXEC}/ensure-image.sh"; }

all_paths() {
	[[ $# -ge 1 ]] || return 1
	for arg in "$@"; do [[ -e "${arg}" ]] || return 1; done
}

nested_warning() {
	echo "WARNING: Nested container mode disables SELinux confinement (--security-opt label=disable)." >&2
	echo "         The container has reduced isolation from the host." >&2
	echo "" >&2
}

socket_warning() {
	echo "WARNING: Socket mode bind-mounts the host podman socket into the container." >&2
	echo "         This grants the container effective root on the host. Use only" >&2
	echo "         with trusted code — this is a broader trust delegation than nested" >&2
	echo "         mode. See README \"Container runtime modes\" for alternatives." >&2
	echo "" >&2
}

usage() {
	cat <<EOF
Usage: riotbox [--agent=<name>] <command> [args...]

Global flags:
  --agent=<claude|opencode>    Select the AI agent (default: claude).
                               May also be set via RIOTBOX_AGENT env var.

Session commands:
  .                            Open a shell in the current directory
  shell [projects...]          Open a shell (explicit)
  run "prompt" [projects...]   Run the agent with a prompt
  resume [projects...]         Resume the last session
  audit [args...]              Audit an untrusted repo (read-only workspace)
  reown [flags...]             Rewrite the agent's commits to your git identity

Privileged session modes (reduced isolation — see README):
  nested-run / nested-shell    Enable nested podman (disables SELinux confinement)
  socket-run / socket-shell    Share the host podman socket (grants host root)

Session management:
  session-list                 List all RiotBox sessions
  session-remove [key/path]    Remove a session (or --all)
  session-reset [all] [force]  Reset session cache

Overlay commands (podman-only):
  overlays                     List sessions with pending overlay data
  overlay-diff [project]       Show overlay changes vs host project
  overlay-accept [project]     Apply overlay changes to host project
  overlay-reject [project]     Discard overlay changes

Setup / maintenance:
  mounts                       Show what would be mounted from your home dir
  install-hooks [flags...]     Install the git pre-push identity hook
  build                        Build the RiotBox image
  rebuild                      Rebuild the image from scratch (no cache)
  update                       Upgrade only the LLM CLI tools (headroom, opencode, Claude Code, plugins)

Info:
  agents                       List registered agents (name + binary)
  doctor                       Verify host setup (preflight checks)
  version                      Show the current version
  help                         Show this help
EOF
}

# ── --agent parsing (consumed before dispatch) ────────────────────────────
RIOTBOX_AGENT="${RIOTBOX_AGENT:-claude}"
while [[ $# -gt 0 ]]; do
	case "$1" in
	--agent=*)
		RIOTBOX_AGENT="${1#--agent=}"
		shift
		;;
	# Shift the flag always, the value only if present, so a trailing bare
	# `--agent` leaves RIOTBOX_AGENT empty and falls through to validation
	# below (exit 2 with a message) instead of aborting under `set -e` on a
	# failed `shift 2`.
	--agent)
		RIOTBOX_AGENT="${2:-}"
		shift
		[[ $# -gt 0 ]] && shift
		;;
	*) break ;;
	esac
done
# shellcheck disable=SC2310  # agent_is_registered returns non-zero; set -e is suppressed in if-condition intentionally
if ! agent_is_registered "${RIOTBOX_AGENT}"; then
	_registry_csv="$(agent_registry_csv)"
	echo "Error: --agent must be one of: ${_registry_csv} (got: ${RIOTBOX_AGENT})" >&2
	exit 2
fi
export RIOTBOX_AGENT

cmd="${1:-}"
[[ $# -gt 0 ]] && shift
[[ -z "${cmd}" ]] && {
	usage
	exit 0
}

# Per-command --help / -h. Lifted out of the dispatch case so every verb
# gets the same treatment without having to remember the pattern. Help
# routes either to a subcommand's own usage block (when it has one) or
# to a short stanza printed here. Without this, `riotbox audit --help`
# was treated as the prompt argument and silently sent to the agent.
print_command_help() {
	case "$1" in
	audit) exec "${LIBEXEC}/audit.sh" --help ;;
	install-hooks) exec "${LIBEXEC}/install-hooks.sh" --help ;;
	build | rebuild | update)
		echo "Usage: riotbox ${1}"
		echo ""
		echo "Introspect the host environment (nvm, uv, Go, Rust, RVM) and build"
		echo "the container image."
		echo "  build    Build using the layer cache where possible."
		echo "  rebuild  Add --no-cache to invalidate every layer."
		echo "  update   Re-pull only the LLM CLI tools (headroom, opencode, Claude Code,"
		echo "           plugins) — headroom re-installs at its pinned version; opencode,"
		echo "           Claude Code, and plugins update to latest. Reuses every other cached layer."
		echo "Environment knobs:"
		echo "  NODE_VERSIONS_MAX=<N>|all  Cap baked-in Node versions (default 3)"
		echo "  RIOTBOX_DIAGRAMS=1         Include Chromium + mmdc"
		echo "  RIOTBOX_NONINTERACTIVE_BUILD=1  Skip the proceed prompt"
		echo "  IMAGE_NAME=<tag>           Override the image tag"
		;;
	doctor)
		echo "Usage: riotbox doctor"
		echo ""
		echo "Walk every host prerequisite and print a fix hint per failure."
		echo "Returns the FIRST failure's exit code (0 on full pass)."
		echo "Environment knobs:"
		echo "  RIOTBOX_DOCTOR_QUIET=1       Print only failures"
		echo "  RIOTBOX_DOCTOR_JSON=1        Emit JSON lines (one per check)"
		echo "  RIOTBOX_DOCTOR_FIRST_FAIL=1  Stop at the first failure"
		echo "  IMAGE_NAME=<tag>             Probe a tag other than 'riotbox'"
		;;
	mounts)
		echo "Usage: riotbox mounts [project ...]"
		echo ""
		echo "Print the mount table that would be applied at launch for the"
		echo "given projects (or CWD if none). Side-effect-free: no session"
		echo "dir is created."
		;;
	*)
		# Fall back to the global usage; common verbs are documented
		# there. Avoid pretending we have a man page for everything.
		usage
		;;
	esac
}

if [[ "${1:-}" = "-h" ]] || [[ "${1:-}" = "--help" ]]; then
	print_command_help "${cmd}"
	exit 0
fi

case "${cmd}" in
help | -h | --help) usage ;;
version | --version | -V) echo "riotbox ${VERSION}" ;;
doctor) exec "${SCRIPTS}/preflight.sh" "$@" ;;
agents)
	agents_max_width=0
	for agent in "${AGENT_REGISTRY[@]}"; do
		[[ "${#agent}" -gt "${agents_max_width}" ]] && agents_max_width="${#agent}"
	done
	for agent in "${AGENT_REGISTRY[@]}"; do
		binary="$(agent_call "${agent}" real_binary)"
		printf "%-${agents_max_width}s  %s\n" "${agent}" "${binary}"
	done
	;;

build) exec "${SCRIPTS}/build.sh" ;;
rebuild) CONTAINER_EXTRA_ARGS="--no-cache" exec "${SCRIPTS}/build.sh" ;;
update) LLM_TOOL_UPDATE="$(date +%s)" exec "${SCRIPTS}/build.sh" ;;

run)
	ensure_image
	exec "${LIBEXEC}/run.sh" "$@"
	;;
shell)
	ensure_image
	export RIOTBOX_PROJECTS="${*:-.}"
	"${LIBEXEC}/checkpoint.sh"
	exec "${LIBEXEC}/launch.sh" bash
	;;
resume)
	ensure_image
	export RIOTBOX_PROJECTS="${*:-.}"
	"${LIBEXEC}/checkpoint.sh"
	exec "${LIBEXEC}/resume.sh"
	;;
audit)
	# Argument validation must run before ensure_image — otherwise a
	# user who forgot the prompt gets "image not found" instead of the
	# usage hint, which is a confusing first interaction.
	if [[ $# -eq 0 ]] || [[ "${1:-}" = "-h" ]] || [[ "${1:-}" = "--help" ]]; then
		exec "${LIBEXEC}/audit.sh" "$@"
	fi
	ensure_image
	exec "${LIBEXEC}/audit.sh" "$@"
	;;

nested-run)
	ensure_image
	export RIOTBOX_NESTED=1
	nested_warning
	exec "${LIBEXEC}/run.sh" "$@"
	;;
nested-shell)
	ensure_image
	export RIOTBOX_NESTED=1 RIOTBOX_PROJECTS="${*:-.}"
	nested_warning
	"${LIBEXEC}/checkpoint.sh"
	exec "${LIBEXEC}/launch.sh" bash
	;;
socket-run)
	ensure_image
	export RIOTBOX_SOCKET=1
	socket_warning
	exec "${LIBEXEC}/run.sh" "$@"
	;;
socket-shell)
	ensure_image
	export RIOTBOX_SOCKET=1 RIOTBOX_PROJECTS="${*:-.}"
	socket_warning
	"${LIBEXEC}/checkpoint.sh"
	exec "${LIBEXEC}/launch.sh" bash
	;;

session-list) exec "${LIBEXEC}/list-sessions.sh" ;;
session-remove) exec "${LIBEXEC}/remove-session.sh" "$@" ;;
session-reset) exec "${LIBEXEC}/reset-session.sh" "$@" ;;

overlays) exec "${SCRIPTS}/overlay.sh" list ;;
overlay-diff) exec "${SCRIPTS}/overlay.sh" diff "$@" ;;
overlay-accept) exec "${SCRIPTS}/overlay.sh" accept "$@" ;;
overlay-reject) exec "${SCRIPTS}/overlay.sh" reject "$@" ;;

reown) exec "${SCRIPTS}/reown-commits.sh" "$@" ;;
install-hooks) exec "${LIBEXEC}/install-hooks.sh" "$@" ;;
mounts)
	# Two groups, surfaced together so the output matches what a real
	# launch does:
	#   1. detect-mounts.sh — functional bind mounts + named caches +
	#      anything in mounts.conf (read at run time from system + XDG).
	#   2. mount-projects.sh --format=triple — the per-project bind and
	#      the session-dir mount, computed against the project paths
	#      given on the command line (or CWD if none).
	# A `mounts` invocation that only shows group 1 missed group 2,
	# which left users debugging missing mounts confused about why
	# `riotbox mounts` and the actual launch disagreed.
	#
	# RIOTBOX_DRY_RUN=1 keeps this command side-effect-free: no session
	# dir gets created, no agent host_sync hook writes files. Agent-
	# contributed mounts (credentials nest, opencode auth) are listed
	# separately as a static note so the user knows what gets added.
	echo "Auto-detected (always-mounted) — from scripts/detect-mounts.sh:"
	"${SCRIPTS}/detect-mounts.sh" | while read -r _flag path; do echo "  ${path}"; done
	echo ""
	echo "Project + session — for: ${*:-$(pwd)} (from scripts/mount-projects.sh):"
	RIOTBOX_DRY_RUN=1 RIOTBOX_PROJECTS="${*:-$(pwd)}" \
		"${SCRIPTS}/mount-projects.sh" --format=triple |
		while IFS= read -r line; do echo "  ${line}"; done
	echo ""
	echo "Agent host_sync — added at launch by the selected --agent (not shown above):"
	echo "  ~/.claude/.credentials.json → session-nested credentials (RW bind)"
	echo "  ~/.claude.json → session-dir copy"
	echo "  ~/.claude/{skills,agents,commands,output-styles,rules,CLAUDE.md} → session-dir copy"
	echo "  ~/.claude/plugins/ → ~/.host-plugins (RO bind, when host plugins exist)"
	echo "  ~/.local/share/opencode/auth.json → in-place RW bind (when opencode is registered)"
	;;

*)
	# shellcheck disable=SC2310  # all_paths uses return codes for control flow; set -e suppression is intentional
	if all_paths "${cmd}" "$@"; then
		ensure_image
		set -- "${cmd}" "$@"
		export RIOTBOX_PROJECTS="$*"
		"${LIBEXEC}/checkpoint.sh"
		exec "${LIBEXEC}/launch.sh" bash
	else
		echo "Error: unknown command '${cmd}'. Run 'riotbox help'." >&2
		exit 2
	fi
	;;
esac
