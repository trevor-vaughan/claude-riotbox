#!/usr/bin/env bash
# RIOTBOX-HOOK: pre-push
# Block pushes containing commits by any riotbox container identity
# (claude@riotbox is current; riotbox@local is the legacy squash-merge identity).
#
# Install: claude-riotbox install-hooks
# Or manually: cp hooks/pre-push .git/hooks/pre-push
set -euo pipefail

remote="$1"
url="$2"

while read -r local_ref local_oid remote_ref remote_oid; do
    # Skip delete pushes
    if [ "${local_oid}" = "0000000000000000000000000000000000000000" ]; then
        continue
    fi

    # Determine the range to check
    if [ "${remote_oid}" = "0000000000000000000000000000000000000000" ]; then
        # New branch — check all commits
        range="${local_oid}"
    else
        range="${remote_oid}..${local_oid}"
    fi

    # Look for commits authored by any riotbox container identity.
    # claude@riotbox is current; riotbox@local is the legacy identity from the
    # old squash-merge code (pre-ff-only fix).
    bad_commits="$(git log --format='%h %ae %s' "${range}" -- 2>/dev/null \
        | grep -E 'claude@riotbox|riotbox@local' || true)"
    if [ -n "${bad_commits}" ]; then
        echo "ERROR: Push blocked — found commits authored by a riotbox container identity:" >&2
        echo "" >&2
        echo "${bad_commits}" | sed 's/^/  /' >&2
        echo "" >&2
        echo "Rewrite these commits to use your identity before pushing:" >&2
        echo "  claude-riotbox reown --all" >&2
        echo "" >&2
        exit 1
    fi
done

exit 0
