# ─────────────────────────────────────────────────────────────────────────────
# Lightweight test image for setup.sh and install.sh
# CentOS Stream 10 with podman, fuse-overlayfs, task, and venom.
# ─────────────────────────────────────────────────────────────────────────────
FROM quay.io/centos/centos:stream10

RUN dnf -y install \
        bash \
        git \
        gnupg2 \
        podman \
        fuse-overlayfs \
        jq \
    && dnf clean all

# venom (integration test runner)
# TODO(security): No checksums or signatures published upstream.
RUN curl -sSfL -o /usr/local/bin/venom \
        https://github.com/ovh/venom/releases/latest/download/venom.linux-amd64 && \
    chmod +x /usr/local/bin/venom

# git-filter-repo (single-file Python script)
# TODO(security): Fetched from main branch with no checksum verification.
#   Consider pinning to a tagged release.
RUN dnf -y install python3 && dnf clean all && \
    curl -sSfL https://raw.githubusercontent.com/newren/git-filter-repo/main/git-filter-repo \
        -o /usr/local/bin/git-filter-repo && \
    chmod +x /usr/local/bin/git-filter-repo

# task
RUN curl --proto '=https' --tlsv1.2 -sSf https://taskfile.dev/install.sh | \
    sh -s -- -b /usr/local/bin

# Non-root test user
ARG HOST_UID=1000
RUN useradd -l -m -u ${HOST_UID} -s /bin/bash testuser 2>/dev/null || \
    useradd -l -m -s /bin/bash testuser

USER testuser
WORKDIR /home/testuser/riotbox
